{
  "name": "butterclaw",
  "version": "0.2.0",
  "description": "Lightweight local agent runtime.",
  "type": "module",
  "bin": {
    "butterclaw": "./dist/src/bin.js",
    "buterclaw": "./dist/src/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "install:local": "npm install -g .",
    "test": "tsc && node --test \"dist/test/**/*.test.js\"",
    "start": "node dist/src/bin.js",
    "setup": "node dist/src/bin.js setup"
  },
  "keywords": [
    "agent",
    "ai",
    "ollama",
    "local-first",
    "automation",
    "typescript"
  ],
  "author": "Butterclaw contributors",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
